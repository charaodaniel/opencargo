# ═══════════════════════════════════════════════════════
# OpenCargo — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════
#
# Instruções:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores
#   3. O .env está no .gitignore → NÃO comite ele
#
# Para deploy no Vercel (frontend), configure estas vars
# no Dashboard > Settings > Environment Variables.
# ═══════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── Autenticação JWT ──────────────────────────────────
# Em producao: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=opencargo-dev-secret
JWT_EXPIRES_IN=7d

# ── Banco de Dados ────────────────────────────────────
# SQLite (dev): file:./data/opencargo.db
# PostgreSQL (prod): postgres://usuario:senha@host:5432/opencargo
# Nao use ?sslmode=require — SSL gerenciado pelo adaptador
DATABASE_URL=file:./data/opencargo.db

# ── CORS ──────────────────────────────────────────────
# Origens separadas por virgula
# Ex: http://localhost:5173,https://opencargo.vercel.app
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ── Rate Limit ────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
