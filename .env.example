# ═══════════════════════════════════════════════════════
# OpenCargo — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════
#
# Instruções:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores obrigatórios marcados com ⚠️
#   3. O arquivo .env está no .gitignore → NÃO comite ele
#      (seu .env contém segredos como JWT_SECRET)
#
# ═══════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────

# Porta onde o servidor HTTP será executado
# Tipo: number | Default: 3000
# PORT=3000

# Host do servidor (0.0.0.0 para todas as interfaces)
# Tipo: string | Default: "0.0.0.0"
# HOST=0.0.0.0

# Ambiente de execução
# Valores: development | production | test
# Tipo: enum | Default: "development"
# NODE_ENV=development

# ── Autenticação JWT ──────────────────────────────────

# ⚠️  Chave secreta para assinar tokens JWT.
#     Em produção, gere um valor forte e único:
#       node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Tipo: string | Default: "opencargo-dev-secret"
JWT_SECRET=opencargo-dev-secret

# Tempo de expiração dos tokens JWT
# Formato: número + d (dias), h (horas), m (minutos)
# Tipo: string | Default: "7d"
# JWT_EXPIRES_IN=7d

# ── Banco de Dados ────────────────────────────────────

# URL de conexão com o banco de dados
# SQLite (dev):   file:./data/opencargo.db
# PostgreSQL:     postgresql://usuario:senha@host:5432/opencargo
# Tipo: string | Default: "file:./data/opencargo.db"
# DATABASE_URL=file:./data/opencargo.db

# ── CORS ──────────────────────────────────────────────

# ⚠️  Origem permitida para requisições CORS.
#     Em produção, defina o domínio do frontend.
#     Ex: https://app.opencargo.com
# Tipo: string | Default: "http://localhost:5173"
# CORS_ORIGIN=http://localhost:5173

# ── Rate Limit ────────────────────────────────────────

# Número máximo de requisições por janela de tempo
# Tipo: number | Default: 100
# RATE_LIMIT_MAX=100

# Duração da janela de rate limit em milissegundos
# 60000 = 1 minuto | 3600000 = 1 hora
# Tipo: number | Default: 60000
# RATE_LIMIT_WINDOW_MS=60000
