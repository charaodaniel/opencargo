# OpenCargo — Variáveis de Ambiente

# Servidor
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Autenticação
JWT_SECRET=sua-chave-secreta-aqui
JWT_EXPIRES_IN=7d

# Banco de Dados
DATABASE_URL=file:./data/opencargo.db
# Para PostgreSQL em produção:
# DATABASE_URL=postgres://user:password@localhost:5432/opencargo

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limit
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
